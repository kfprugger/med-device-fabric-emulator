{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensions": {
    "durableTask": {
      "hubName": "MedDeviceDeployHub",
      "storageProvider": {
        "maxQueuePollingInterval": "00:00:05"
      }
    },
    "http": {
      "routePrefix": "api",
      "cors": {
        "allowedOrigins": ["*"],
        "supportCredentials": false
      }
    }
  },
  "functionTimeout": "02:00:00",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}
