      "title": "Selected Device Vitals",
      "query": "fn_LatestReadings() | where device_id in (_selectedDevices) | extend spo2_status=case(spo2 < 85, 'Critical', spo2 < 90, 'Urgent', spo2 < 94, 'Warning', 'Normal'), pr_status=case(pr > 150 or pr < 40, 'Critical', pr > 130 or pr < 45, 'Urgent', pr > 110 or pr < 50, 'Warning', 'Normal'), signal_status=case(signal_iq < 95, 'Check sensor', 'Good') | project device_id, timestamp, spo2_status, spo2, pr_status, pr, pi, pvi, sphb, signal_status, signal_iq | order by spo2 asc",
