      "id": "d07043ec-f989-505a-83c1-c5b2ccfb55b6",
      "title": "Selected Device SpO₂ + Alert Markers + Thresholds",
      "query": "let readings = TelemetryRaw | where todatetime(timestamp) > ago(2h) | where device_id in (_selectedDevices) | summarize value=round(avg(todouble(telemetry.spo2)), 1) by series=device_id, ts=bin(todatetime(timestamp), 30s); let buckets = readings | summarize by ts; let alert_markers = fn_ClinicalAlerts(120) | where device_id in (_selectedDevices) | project series=strcat('Alert ', alert_tier), ts=bin(alert_time, 30s), value=spo2; readings | union alert_markers | union (buckets | extend series='Warning threshold 94', value=94.0) | union (buckets | extend series='Urgent threshold 90', value=90.0) | union (buckets | extend series='Critical threshold 85', value=85.0) | order by ts asc | render timechart",
      "layout": {
        "x": 12,
        "y": 0,
        "width": 12,
        "height": 7
