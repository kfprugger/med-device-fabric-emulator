    {
      "id": "1d24448c-f04e-57e7-911b-6bf4e2746956",
      "title": "SpO₂ Trend + Alert Markers + Thresholds",
      "query": "let readings = TelemetryRaw | where todatetime(timestamp) > ago(60m) | where device_id in (_selectedDevices) | summarize value=round(avg(todouble(telemetry.spo2)), 1) by series=device_id, ts=bin(todatetime(timestamp), 30s); let buckets = readings | summarize by ts; let alert_markers = fn_ClinicalAlerts(60) | where device_id in (_selectedDevices) | project series=strcat('Alert ', alert_tier), ts=bin(alert_time, 30s), value=spo2; readings | union alert_markers | union (buckets | extend series='Warning threshold 94', value=94.0) | union (buckets | extend series='Urgent threshold 90', value=90.0) | union (buckets | extend series='Critical threshold 85', value=85.0) | order by ts asc | render timechart",
      "layout": {
        "x": 14,
        "y": 3,
        "width": 10,
        "height": 8
      },
      "pageId": "8ab7acbb-ddca-4b94-b124-64030817ff8d",
