    {"column": "patient_id",            "path": "$.patient_id",            "datatype": "string"},
    {"column": "provider_id",           "path": "$.provider_id",           "datatype": "string"},
    {"column": "facility_id",           "path": "$.facility_id",           "datatype": "string"},
    {"column": "payer_id",              "path": "$.payer_id",              "datatype": "string"},
    {"column": "diagnosis_code",        "path": "$.diagnosis_code",        "datatype": "string"},
    {"column": "procedure_code",        "path": "$.procedure_code",        "datatype": "string"},
    {"column": "claim_type",            "path": "$.claim_type",            "datatype": "string"},
    {"column": "claim_amount",          "path": "$.claim_amount",          "datatype": "real"},
    {"column": "latitude",              "path": "$.latitude",              "datatype": "real"},
