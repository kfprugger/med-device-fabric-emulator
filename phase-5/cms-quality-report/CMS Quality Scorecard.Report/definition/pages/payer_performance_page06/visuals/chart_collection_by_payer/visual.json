{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.5.0/schema.json",
  "name": "chart_collection_by_payer",
  "position": {
    "z": 2000,
    "x": 10,
    "width": 570,
    "y": 160,
    "height": 530,
    "tabOrder": 2000
  },
  "visual": {
    "visualType": "barChart",
    "drillFilterOtherVisuals": true,
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "nativeQueryRef": "payer_category",
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_payer"
                    }
                  },
                  "Property": "payer_category"
                }
              },
              "queryRef": "dim_payer.payer_category"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "nativeQueryRef": "Collection Rate",
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Collection Rate"
                }
              },
              "queryRef": "_Measures.Collection Rate"
            }
          ]
        }
      }
    }
  }
}