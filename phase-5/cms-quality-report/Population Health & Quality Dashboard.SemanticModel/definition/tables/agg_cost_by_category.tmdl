/// Cost breakdown by service and payer category
table agg_cost_by_category
	lineageTag: d3000001-aaaa-bbbb-cccc-d30000000001

	partition 'agg_cost_by_category' = entity
		mode: directLake
		source
			entityName: agg_cost_by_category
			schemaName: dbo
			expressionSource: ReportingGoldSource

	column service_category
		dataType: string
		lineageTag: d3000001-aaaa-bbbb-cccc-d30000000002
		sourceColumn: service_category
		summarizeBy: none

	column payer_category
		dataType: string
		lineageTag: d3000001-aaaa-bbbb-cccc-d30000000003
		sourceColumn: payer_category
		summarizeBy: none

	column claim_count
		dataType: int64
		lineageTag: d3000001-aaaa-bbbb-cccc-d30000000004
		sourceColumn: claim_count
		summarizeBy: none

	column total_billed
		dataType: double
		lineageTag: d3000001-aaaa-bbbb-cccc-d30000000005
		sourceColumn: total_billed
		summarizeBy: none

	column total_paid
		dataType: double
		lineageTag: d3000001-aaaa-bbbb-cccc-d30000000006
		sourceColumn: total_paid
		summarizeBy: none

	column avg_claim_amount
		dataType: double
		lineageTag: d3000001-aaaa-bbbb-cccc-d30000000007
		sourceColumn: avg_claim_amount
		summarizeBy: none

	column denied_claims
		dataType: int64
		lineageTag: d3000001-aaaa-bbbb-cccc-d30000000008
		sourceColumn: denied_claims
		summarizeBy: none

	column load_timestamp
		dataType: dateTime
		lineageTag: d3000001-aaaa-bbbb-cccc-d30000000009
		sourceColumn: load_timestamp
		summarizeBy: none
