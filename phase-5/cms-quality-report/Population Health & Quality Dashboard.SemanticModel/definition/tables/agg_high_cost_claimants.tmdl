/// High cost claimant identification and stop-loss flagging
table agg_high_cost_claimants
	lineageTag: d4000001-aaaa-bbbb-cccc-d40000000001

	partition 'agg_high_cost_claimants' = entity
		mode: directLake
		source
			entityName: agg_high_cost_claimants
			schemaName: dbo
			expressionSource: ReportingGoldSource

	column patient_id
		dataType: string
		lineageTag: d4000001-aaaa-bbbb-cccc-d40000000002
		sourceColumn: patient_id
		summarizeBy: none

	column payer_category
		dataType: string
		lineageTag: d4000001-aaaa-bbbb-cccc-d40000000003
		sourceColumn: payer_category
		summarizeBy: none

	column total_paid
		dataType: double
		lineageTag: d4000001-aaaa-bbbb-cccc-d40000000004
		sourceColumn: total_paid
		summarizeBy: none

	column total_billed
		dataType: double
		lineageTag: d4000001-aaaa-bbbb-cccc-d40000000005
		sourceColumn: total_billed
		summarizeBy: none

	column claim_count
		dataType: int64
		lineageTag: d4000001-aaaa-bbbb-cccc-d40000000006
		sourceColumn: claim_count
		summarizeBy: none

	column denied_claims
		dataType: int64
		lineageTag: d4000001-aaaa-bbbb-cccc-d40000000007
		sourceColumn: denied_claims
		summarizeBy: none

	column percentile_rank
		dataType: double
		lineageTag: d4000001-aaaa-bbbb-cccc-d40000000008
		sourceColumn: percentile_rank
		summarizeBy: none

	column is_stop_loss
		dataType: boolean
		lineageTag: d4000001-aaaa-bbbb-cccc-d40000000009
		sourceColumn: is_stop_loss
		summarizeBy: none

	column conditions_list
		dataType: string
		lineageTag: d4000001-aaaa-bbbb-cccc-d4000000000a
		sourceColumn: conditions_list
		summarizeBy: none

	column load_timestamp
		dataType: dateTime
		lineageTag: d4000001-aaaa-bbbb-cccc-d4000000000b
		sourceColumn: load_timestamp
		summarizeBy: none
