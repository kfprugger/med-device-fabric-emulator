model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["person", "condition_occurrence", "drug_exposure", "measurement", "concept", "_Measures"]

annotation PBI_ProTooling = ["DevMode", "TMDL-Extension"]

ref table person
ref table condition_occurrence
ref table drug_exposure
ref table measurement
ref table concept
ref table _Measures

ref cultureInfo en-US
