        "principalId": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', 'claim-emulator-grp'), '2023-05-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerInstance/containerGroups', 'claim-emulator-grp')]"
